flowchart LR
    VP["validation_pack_result.v1"]
    SM["cross_project_smoke_result.v1"]
    SS["status_snapshot.v1"]
    AD["adapter_manifest.v1"]
    RT["runtime/project context"]
    ACT_SOURCE["review-action derivation<br/>executable: false"]

    FRESH_POLICY["evidence freshness policy v1"]
    FRESH_CLI["python -m dev_cockpit.evidence_freshness"]
    FRESH_RECEIPT["evidence_freshness_receipt.v1<br/>validated point-in-time input"]

    REPORT_MANIFEST["task_report_manifest.v1<br/>explicit paths + SHA-256"]
    AGENT_REPORTS["manifest-bound AGENT_REPORT files"]
    NORMALIZER["report_normalizer"]
    CLASSIFIER["gate_classifier"]
    PACKET["cross_project_supervision_packet.v1<br/>non-executable"]
    GLOBAL_QUEUE["global attention queue<br/>rank is review priority"]
    WORKSETS["project worksets<br/>same task IDs + ranks"]

    GEN["dev_cockpit.dashboard<br/>production generator"]
    POLICY["deterministic priority policy<br/>rank + deduplicate"]
    OPTION_A["A: Priority Review Console<br/>selected production direction"]
    SURFACE["priority-review-console-production-observation-surface-v1"]
    STATE["concise current-state strip"]
    PRIORITY["ordered Priority Lane"]
    DECISION["Active Decision"]
    EVIDENCE["Evidence Inspector<br/>freshness + provenance"]
    APPENDIX["subordinate evidence appendix"]

    HTML["devcockpitcore_dashboard.html"]
    PRIORITY_JSON["devcockpitcore_priority_readback.json"]
    ACTION_JSON["devcockpitcore_review_actions.json"]
    ACTION_MD["devcockpitcore_review_actions.md"]
    CAPTURE["production_capture<br/>JA desktop + EN desktop + JA narrow"]
    USER_REVIEW["production visual acceptance<br/>accepted"]

    HISTORY["v2 A/B/C comparison<br/>historical selection provenance"]
    OPTION_B["B: Narrative Status Brief<br/>possible future handoff/summary only"]
    OPTION_C["C: Lane And Project Overview<br/>possible future cross-project overview only"]
    FUTURE_NEED["future observed secondary-view need"]

    VP --> FRESH_RECEIPT
    SM --> FRESH_RECEIPT
    SS --> FRESH_RECEIPT
    AD --> FRESH_RECEIPT
    RT --> FRESH_RECEIPT
    FRESH_POLICY --> FRESH_RECEIPT
    FRESH_CLI --> FRESH_RECEIPT

    REPORT_MANIFEST --> AGENT_REPORTS
    AGENT_REPORTS --> NORMALIZER
    NORMALIZER --> CLASSIFIER
    CLASSIFIER --> PACKET
    PACKET --> GLOBAL_QUEUE
    PACKET --> WORKSETS

    VP --> GEN
    SM --> GEN
    SS --> GEN
    AD --> GEN
    RT --> GEN
    FRESH_RECEIPT --> GEN
    PACKET -. "explicit --supervision-packet" .-> GEN
    GEN --> POLICY
    GEN --> ACT_SOURCE
    ACT_SOURCE --> POLICY
    POLICY --> OPTION_A
    OPTION_A --> SURFACE

    SURFACE --> STATE
    SURFACE --> PRIORITY
    PRIORITY --> DECISION
    DECISION --> EVIDENCE
    SURFACE --> APPENDIX
    EVIDENCE --> APPENDIX
    GLOBAL_QUEUE --> PRIORITY
    WORKSETS -. "secondary same-ID projection" .-> APPENDIX

    STATE --> HTML
    PRIORITY --> HTML
    DECISION --> HTML
    EVIDENCE --> HTML
    APPENDIX --> HTML
    POLICY --> PRIORITY_JSON
    ACT_SOURCE --> ACTION_JSON
    ACT_SOURCE --> ACTION_MD
    HTML --> CAPTURE
    PRIORITY_JSON --> CAPTURE
    CAPTURE --> USER_REVIEW

    HISTORY -. "A selection completed" .-> OPTION_A
    FUTURE_NEED -. "only if observed" .-> OPTION_B
    FUTURE_NEED -. "only if observed" .-> OPTION_C

    NAV["README / Cockpit / runtime-state / decision-log<br/>navigation and decision records, not live authority"]
    NAV -. "points to" .-> HTML
    NAV -. "points to" .-> PRIORITY_JSON
    NAV -. "points to" .-> CAPTURE

    LOCK["locked: runner, scheduler, server, external services,<br/>credentials, notifications, target writeback"]
    LOCK -. "not actionable priorities" .-> POLICY
