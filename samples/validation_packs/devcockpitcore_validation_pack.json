      "kind": "json",
      "severity": "required",
      "enabled": true,
      "paths": [
        "adapters",
        "samples"
      ],
      "targets": [],
      "allow_fixture_hits": false,
      "notes": []
    },
    {
      "check_key": "git_diff_check",
      "kind": "git",
      "severity": "required",
      "enabled": true,
      "paths": [],
      "targets": [],
      "allow_fixture_hits": false,
      "notes": []
    },
    {
      "check_key": "git_diff_cached_check",
      "kind": "git",
      "severity": "warning",
      "enabled": true,
      "paths": [],
      "targets": [],
      "allow_fixture_hits": false,
